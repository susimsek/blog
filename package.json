{
  "name": "blog",
  "version": "1.0.0",
  "private": true,
  "description": "Blog application",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prettier:format": "prettier --write */**/*.{md,json,yml,yaml,js,cjs,mjs,ts,tsx,css,scss,html}",
    "prettier:check": "prettier --check */**/*.{md,json,yml,yaml,js,cjs,mjs,ts,tsx,css,scss,html}",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "i18n:interface": "i18next-resources-for-ts interface -i ./public/locales/en -o ./src/types/i18n-resources.d.ts",
    "build": "rimraf build && next build",
    "postbuild": "node scripts/generate-sitemap.js && node scripts/generate-rss.js && node scripts/generate-robots.js",
    "webapp:dev": "rimraf build && next dev",
    "webapp:prod": "rimraf build && next build",
    "webapp:build:prod": "next build",
    "clean-www": "rimraf build",
    "sonar": "pnpm exec sonar-scanner",
    "backend:test": "go test ./...",
    "backend:ci": "go test ./... -coverprofile=coverage/go-cover.out",
    "backend:lint": "go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.10.1 run",
    "backend:lint:report": "go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.10.1 run --output.checkstyle.path=golangci-lint-report.xml --output.text.path=stdout --output.text.colors=false",
    "jest": "jest --coverage --maxWorkers=2 --config jest.config.js",
    "test": "jest --coverage --maxWorkers=2 --config jest.config.js",
    "test:watch": "jest --coverage --maxWorkers=2 --config jest.config.js --watch",
    "fetch:medium": "node scripts/fetch-medium-feed.js && node scripts/sync-medium-posts.js",
    "sync:medium-posts": "node scripts/sync-medium-posts.js",
    "sync:post-metadata": "node scripts/sync-post-metadata.js",
    "sync:reading-time": "node scripts/sync-post-metadata.js",
    "sync:code-filenames": "node scripts/sync-code-filename-meta.js",
    "graphql:generate": "GOCACHE=/tmp/go-build go run github.com/99designs/gqlgen generate && GOCACHE=/tmp/go-build go run github.com/99designs/gqlgen generate --config admin-gqlgen.yml",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "backend:dev": "go run github.com/air-verse/air@v1.64.5 -c .air.toml",
    "backend:start": "go run ./cmd/app",
    "backend:sync-content": "go run ./scripts/sync-newsletter-content/main.go",
    "backend:sync-admin-error-messages": "go run ./scripts/sync-admin-error-messages/main.go"
  },
  "dependencies": {
    "@apollo/client": "^4.2.5",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@next/third-parties": "^16.2.10",
    "@reduxjs/toolkit": "^2.12.0",
    "bootstrap": "^5.3.8",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "graphql": "^16.12.0",
    "gray-matter": "^4.0.3",
    "hast-util-sanitize": "^5.0.2",
    "i18next": "^26.3.4",
    "lz-string": "^1.5.0",
    "next": "^16.2.10",
    "next-language-detector": "^1.1.1",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rss-parser": "^3.13.0",
    "unified": "^11.0.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typed-document-node": "^7.0.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.5",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.6",
    "i18next-resources-for-ts": "^2.1.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-sonar": "0.2.16",
    "lint-staged": "^17.0.8",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "sonar-scanner": "^3.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
