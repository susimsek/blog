{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/newsletter-dispatch/*.go": {
      "maxDuration": 60
    },
    "api/**/*.go": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/graphql",
      "destination": "/api/graphql"
    },
    {
      "source": "/api/admin/graphql",
      "destination": "/api/admin-graphql"
    },
    {
      "source": "/api/reader-auth/session",
      "destination": "/api/reader-auth"
    },
    {
      "source": "/api/reader-auth/logout",
      "destination": "/api/reader-auth"
    },
    {
      "source": "/api/admin-google/connect",
      "destination": "/api/admin-google"
    },
    {
      "source": "/api/admin-google/callback",
      "destination": "/api/admin-google"
    },
    {
      "source": "/api/admin-github/connect",
      "destination": "/api/admin-github"
    },
    {
      "source": "/api/admin-github/callback",
      "destination": "/api/admin-github"
    },
    {
      "source": "/api/reader-google/connect",
      "destination": "/api/reader-google"
    },
    {
      "source": "/api/reader-google/callback",
      "destination": "/api/reader-google"
    },
    {
      "source": "/api/reader-github/connect",
      "destination": "/api/reader-github"
    },
    {
      "source": "/api/reader-github/callback",
      "destination": "/api/reader-github"
    }
  ],
  "crons": [
    {
      "path": "/api/newsletter-dispatch",
      "schedule": "0 4 * * *"
    }
  ]
}
